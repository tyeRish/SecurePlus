{
  "appId": "com.tyerish.secplusoperator",
  "appName": "SEC+ Operator",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "buildOptions": {
      "keystorePath": "secplus.keystore",
      "keystoreAlias": "secplus"
    }
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0a0e1a",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "dark",
      "backgroundColor": "#0a0e1a"
    }
  }
}
